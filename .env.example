# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=

# ── JWT (RS256 asymmetric keys — generate with openssl) ───────────────────────
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents here, replacing real newlines with \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
REFRESH_TOKEN_SECRET=
# Generate: openssl rand -hex 32  (NEVER rotate — breaks existing phone hashes)
PHONE_HASH_SALT=

# ── Cloudflare R2 (S3-compatible media storage) ───────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=saanjh-media
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_CDN=

# ── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Push Notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMS OTP (MSG91 — Phase 2, after DLT registration) ────────────────────────
MSG91_AUTH_KEY=

# ── Firebase Auth (OTP for MVP) ───────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=

# ── Infrastructure (optional for MVP) ────────────────────────────────────────
REDIS_URL=
SENTRY_DSN=

# ── Staging isolation (prefix all R2 keys with 'staging/' on staging env) ────
STORAGE_PREFIX=
