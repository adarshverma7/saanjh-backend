# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=

# ── JWT (RS256 asymmetric keys — generate with openssl) ───────────────────────
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents here, replacing real newlines with \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
REFRESH_TOKEN_SECRET=
# Generate: openssl rand -hex 32  (NEVER rotate — breaks existing phone hashes)
PHONE_HASH_SALT=

# ── Backblaze B2 Storage (S3-compatible) ──────────────────────────────────────
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_BUCKET_NAME=saanjh-backend-dev
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/saanjh-backend-dev

# ── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Push Notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMS OTP (MSG91 — Phase 2, after DLT registration) ────────────────────────
MSG91_AUTH_KEY=

# ── Firebase Auth (OTP) ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_JWT_SECRET=

# ── Infrastructure (optional for MVP) ────────────────────────────────────────
REDIS_URL=
SENTRY_DSN=
